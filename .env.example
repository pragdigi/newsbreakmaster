FLASK_SECRET_KEY=change-me-in-production

# Preferred on Render: set once, survives deploys/restarts so you never see the login screen.
# NewsBreak Ad Manager -> Resources -> API Access Tokens
NEWSBREAK_ACCESS_TOKEN=
# Comma-separated NewsBreak organization IDs
NEWSBREAK_DEFAULT_ORG_IDS=

# SmartNews Marketing API v3 uses OAuth client_credentials instead of a
# single API key.
# Create a Developer App at https://ads.smartnews.com/developers and copy the
# Client ID (numeric developer app id) and Client Secret below.
SMARTNEWS_CLIENT_ID=
SMARTNEWS_CLIENT_SECRET=
# Optional: restrict this instance to specific ad accounts (comma separated).
# When empty, the app auto-discovers accounts via
# /api/bm/v1/developer_apps/me/ad_accounts.
SMARTNEWS_DEFAULT_ACCOUNT_IDS=

# Legacy / deprecated. The old v1 ``X-Auth-Api`` key is still read as a
# fallback for SMARTNEWS_CLIENT_SECRET so existing deployments keep working
# while you migrate. v1/v2 APIs are scheduled for sunset on 2026-06-30.
# SMARTNEWS_API_KEY=

# Optional: HTTP Basic Auth protecting the whole app (browser login before anything else)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# =============== AI Ad Studio ===============
# Primary image model: Gemini 3.1 Flash Image (Nano Banana 2). Shared with the
# SmartNews 16:9 outpainter.
GEMINI_API_KEY=
NANO_BANANA_MODEL=gemini-3.1-flash-image-preview

# Secondary image model: OpenAI gpt-image-2 (used for cross-model fallback).
OPENAI_API_KEY=
GPT_IMAGE_MODEL=gpt-image-2

# LLM used to analyse winning ads into AdInsights (primary) and brainstorm
# new styles (fallback). Claude Opus is used when Gemini is unavailable.
ANTHROPIC_API_KEY=
AD_STUDIO_ANALYZER_MODEL=gemini-3.1-pro
AD_STUDIO_GEMINI_MODEL=gemini-3.1-pro-preview
AD_STUDIO_CLAUDE_MODEL=claude-opus-4-7

# Winner detection thresholds (override per offer if your numbers differ).
AD_STUDIO_WINNERS_WINDOW_DAYS=14
AD_STUDIO_WINNERS_MIN_SPEND=20
AD_STUDIO_WINNERS_MIN_CONV=3
AD_STUDIO_WINNERS_CPA_FACTOR=1.0

# Bandit allocator tuning.
AD_STUDIO_BANDIT_FLOOR_WINDOW=30
AD_STUDIO_BANDIT_COLD_START=5
AD_STUDIO_BANDIT_CANDIDATE_MAX=0.4
# Multiplicative damping per recent appearance: arm_score *= (1 - PENALTY * count).
# 0.05 = a style picked twice in last FLOOR_WINDOW batches gets ~10% damped,
# 5x picked → 25% damped. Set 0 to disable rotation pressure entirely.
AD_STUDIO_BANDIT_RECENCY_PENALTY=0.05

# How many recent prompts to feed concept_gen as anti-repetition memory.
# 60 ≈ the last six 10-slot batches. Larger = more diverse, more LLM context.
AD_STUDIO_CONCEPT_MEMORY=60

# Lifecycle thresholds for the research module.
AD_STUDIO_PROMOTE_MIN_TRIALS=20
AD_STUDIO_ARCHIVE_MIN_TRIALS=15
AD_STUDIO_PROMOTE_CPA_EDGE=0.10

# Nightly scheduler (full pass: winners + discover + lifecycle).
AD_STUDIO_NIGHTLY_HOUR=5
AD_STUDIO_NIGHTLY_MINUTE=30
AD_STUDIO_NIGHTLY_KEYWORDS_PER_OFFER=5
AD_STUDIO_NIGHTLY_GETHOOKD_LIMIT=40
AD_STUDIO_NIGHTLY_BRAINSTORM_COUNT=3

# Every-N-hour scout pass (discovery only). Set 0 to disable. Cheaper per-tick
# than the nightly job — uses fewer keywords/results per offer.
AD_STUDIO_SCOUT_HOURS=6
AD_STUDIO_SCOUT_KEYWORDS_PER_OFFER=3
AD_STUDIO_SCOUT_GETHOOKD_LIMIT=20
AD_STUDIO_SCOUT_BRAINSTORM_COUNT=2

# GetHookd competitor-ad discovery (covers Meta + TikTok + Google supply).
# Shared with the `creative_brief_tool` project — same key works here.
GETHOOKD_API_KEY=
GETHOOKD_BASE_URL=https://app.gethookd.ai/api/v1

# --- Public-libraries scout (Agent #2) -------------------------------------
# No API token required. Scrapes facebook.com/ads/library + TikTok Creative
# Center directly with a browser User-Agent. FB_AD_LIBRARY_TOKEN is OPTIONAL
# — when set, falls back to the official Graph API for queries the HTML
# scraper can't satisfy (e.g. when FB serves a checkpoint page).
AD_STUDIO_PUBLIC_SCOUT_HOURS=12
AD_STUDIO_PUBLIC_SCOUT_KEYWORDS_PER_OFFER=3
AD_STUDIO_PUBLIC_SCOUT_LIMIT_PER_QUERY=20
AD_STUDIO_PUBLIC_SCOUT_COUNTRY=US
AD_STUDIO_PUBLIC_SCOUT_SOURCES=meta,tiktok
FB_AD_LIBRARY_TOKEN=
FB_AD_LIBRARY_GRAPH_VERSION=v20.0
META_AD_LIB_COUNTRY=US
TIKTOK_CREATIVE_REGION=US

# --- Copywriting Scholar (Agent #3) ----------------------------------------
# Pure-LLM deep-research agent. No scraping. Cycles through copywriting
# frameworks (Schwartz, Halbert, Cialdini, Sugarman, Ogilvy, ...) per offer
# per run. Opus primary, Gemini 3.1 Pro fallback. Set hours=0 to disable.
AD_STUDIO_SCHOLAR_HOURS=12
AD_STUDIO_SCHOLAR_COUNT=3
AD_STUDIO_SCHOLAR_PRIMARY=claude-opus-4-7
AD_STUDIO_SCHOLAR_FALLBACK=gemini-3.1-pro-preview
AD_STUDIO_SCHOLAR_MAX_TOKENS=4000

# Managed-agent HTTP surface (/api/agent/*). Set AGENT_SHARED_SECRET to
# enable; the endpoints return 503 while unset. Requests must include
# headers X-Agent-Key, X-Agent-Timestamp, X-Agent-Signature (HMAC-SHA256).
AGENT_SHARED_SECRET=
AGENT_PUBLIC_KEY=default
AGENT_MAX_CLOCK_SKEW=300

