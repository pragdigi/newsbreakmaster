FLASK_SECRET_KEY=change-me-in-production

# Preferred on Render: set once, survives deploys/restarts so you never see the login screen.
# NewsBreak Ad Manager -> Resources -> API Access Tokens
NEWSBREAK_ACCESS_TOKEN=
# Comma-separated NewsBreak organization IDs
NEWSBREAK_DEFAULT_ORG_IDS=

# SmartNews Marketing API v3 uses OAuth client_credentials instead of a
# single API key.
# Create a Developer App at https://ads.smartnews.com/developers and copy the
# Client ID (numeric developer app id) and Client Secret below.
SMARTNEWS_CLIENT_ID=
SMARTNEWS_CLIENT_SECRET=
# Optional: restrict this instance to specific ad accounts (comma separated).
# When empty, the app auto-discovers accounts via
# /api/bm/v1/developer_apps/me/ad_accounts.
SMARTNEWS_DEFAULT_ACCOUNT_IDS=

# Legacy / deprecated. The old v1 ``X-Auth-Api`` key is still read as a
# fallback for SMARTNEWS_CLIENT_SECRET so existing deployments keep working
# while you migrate. v1/v2 APIs are scheduled for sunset on 2026-06-30.
# SMARTNEWS_API_KEY=

# Optional: HTTP Basic Auth protecting the whole app (browser login before anything else)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
