FLASK_SECRET_KEY=change-me-in-production

# Preferred on Render: set once, survives deploys/restarts so you never see the login screen.
# NewsBreak Ad Manager -> Resources -> API Access Tokens
NEWSBREAK_ACCESS_TOKEN=
# Comma-separated NewsBreak organization IDs
NEWSBREAK_DEFAULT_ORG_IDS=

# SmartNews Ads Management API key (sent as the `X-Auth-Api` request header).
# Request one from your SmartNews representative; scope it to the advertiser accounts
# you want this instance to manage.
SMARTNEWS_API_KEY=
# Comma-separated SmartNews advertiser account IDs this token should manage.
# The platform toggle in the UI will use these as the default account set when the
# user switches to SmartNews without logging in again.
SMARTNEWS_DEFAULT_ACCOUNT_IDS=

# Optional: HTTP Basic Auth protecting the whole app (browser login before anything else)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
